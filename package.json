{
  "name": "voycelink-challenge",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.0.0",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently --names \"frontend,call-service,realtime-service\" --prefix-colors \"cyan,yellow,green\" \"pnpm --filter frontend dev\" \"pnpm --filter call-service dev\" \"pnpm --filter realtime-service dev\"",
    "build": "pnpm -r --if-present build",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "eslint packages --ext .js,.ts,.tsx",
    "test": "pnpm -r --if-present test",
    "check": "pnpm run lint && pnpm run typecheck && pnpm run test",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down",
    "setup": "pnpm install && docker compose up -d"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "unrs-resolver"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.32.1",
    "@typescript-eslint/parser": "^8.32.1",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.1",
    "eslint-config-next": "^14.2.35"
  }
}
